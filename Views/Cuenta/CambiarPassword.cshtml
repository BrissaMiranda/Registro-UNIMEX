@model SistemaUniversidad.ViewModels.CambiarPasswordViewModel

@{
    ViewData["Title"] = "Cambiar contraseña";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-5 col-md-7">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-primary text-white text-center rounded-top-4 py-4">

                    <i class="bi bi-shield-lock-fill display-4"></i>

                    <h3 class="mt-2 mb-0">
                        Cambiar Contraseña
                    </h3>

                    <small>
                        Actualiza tu contraseña para mantener tu cuenta protegida.
                    </small>

                </div>

                <div class="card-body p-4">

                    <form asp-action="CambiarPassword" method="post">

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <!-- Contraseña actual -->
                        <div class="mb-4">

                            <label asp-for="PasswordActual" class="form-label fw-semibold">
                                <i class="bi bi-lock-fill me-2"></i>
                                Contraseña actual
                            </label>

                            <div class="input-group">

                                <span class="input-group-text">
                                    <i class="bi bi-key-fill"></i>
                                </span>

                                <input asp-for="PasswordActual"
                                       class="form-control"
                                       type="password"
                                       placeholder="Ingrese su contraseña actual" />

                            </div>

                            <span asp-validation-for="PasswordActual" class="text-danger small"></span>

                        </div>

                        <!-- Nueva contraseña -->
                        <div class="mb-4">

                            <label asp-for="PasswordNueva" class="form-label fw-semibold">
                                <i class="bi bi-lock-fill me-2"></i>
                                Nueva contraseña
                            </label>

                            <div class="input-group">

                                <span class="input-group-text">
                                    <i class="bi bi-shield-lock-fill"></i>
                                </span>

                                <input asp-for="PasswordNueva"
                                       class="form-control"
                                       type="password"
                                       placeholder="Ingrese la nueva contraseña" />

                            </div>

                            <span asp-validation-for="PasswordNueva" class="text-danger small"></span>

                        </div>

                        <!-- Confirmar contraseña -->
                        <div class="mb-4">

                            <label asp-for="ConfirmarPassword" class="form-label fw-semibold">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                Confirmar contraseña
                            </label>

                            <div class="input-group">

                                <span class="input-group-text">
                                    <i class="bi bi-check2-circle"></i>
                                </span>

                                <input asp-for="ConfirmarPassword"
                                       class="form-control"
                                       type="password"
                                       placeholder="Repita la nueva contraseña" />

                            </div>

                            <span asp-validation-for="ConfirmarPassword" class="text-danger small"></span>

                        </div>

                        <div class="d-grid">

                            <button type="submit" class="btn btn-primary btn-lg rounded-3">

                                <i class="bi bi-check-circle-fill me-2"></i>

                                Guardar Cambios

                            </button>

                        </div>
                    </form>

                </div>

                <div class="card-footer text-center bg-light">

                    <small class="text-muted">

                        <i class="bi bi-info-circle"></i>

                        Utiliza una contraseña segura con letras, números y caracteres especiales.

                    </small>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts{

    <script src="~/js/cuenta.js"></script>

}