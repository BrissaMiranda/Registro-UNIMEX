@model SistemaUniversidad.ViewModels.AdministradorViewModel

@using Microsoft.AspNetCore.Http

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Administrador";
}

<h1>Sistema Universitario</h1>

<div class="mb-4">

    <h2 class="fw-bold text-primary">
        <i class="bi bi-speedometer2"></i>
        Panel de Administración
    </h2>

    <p class="text-muted">
        Bienvenido, <strong>@Context.Session.GetString("Usuario")</strong>.
        Desde este panel puede administrar los usuarios del sistema.
    </p>

</div>

<div class="row mb-4">

    <div class="col-md-2 mb-3">
        <div class="card text-center shadow-sm border-primary">
            <div class="card-body">
                <h5>👥</h5>
                <h3>@Model.TotalUsuarios</h3>
                <small>Total Usuarios</small>
            </div>
        </div>
    </div>

    <div class="col-md-2 mb-3">
        <div class="card text-center shadow-sm border-success">
            <div class="card-body">
                <h5>🎓</h5>
                <h3>@Model.TotalEstudiantes</h3>
                <small>Estudiantes</small>
            </div>
        </div>
    </div>

    <div class="col-md-2 mb-3">
        <div class="card text-center shadow-sm border-info">
            <div class="card-body">
                <h5>👨‍🏫</h5>
                <h3>@Model.TotalDocentes</h3>
                <small>Docentes</small>
            </div>
        </div>
    </div>

    <div class="col-md-2 mb-3">
        <div class="card text-center shadow-sm border-warning">
            <div class="card-body">
                <h5>👑</h5>
                <h3>@Model.TotalAdministradores</h3>
                <small>Administradores</small>
            </div>
        </div>
    </div>

    <div class="col-md-2 mb-3">
        <div class="card text-center shadow-sm border-success">
            <div class="card-body">
                <h5>🟢</h5>
                <h3>@Model.UsuariosActivos</h3>
                <small>Usuarios Activos</small>
            </div>
        </div>
    </div>

</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        @TempData["Mensaje"]
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">

    <h2 class="mb-0">
        Usuarios Registrados
    </h2>

    <a asp-controller="Administrador"
       asp-action="CrearUsuario"
       class="btn btn-primary">

       <i class="bi bi-person-plus-fill"></i>
        Registrar Usuario

    </a>

</div>

<hr />

<div class="row mb-3">

    <div class="input-group">

        <span class="input-group-text">
            <i class="bi bi-search"></i>
        </span>

        <input type="text"
            id="buscarUsuario"
            class="form-control"
            placeholder="Buscar usuario, nombre o rol...">

    </div>

</div>

<div class="table-responsive">

<table id="tablaUsuarios"
       class="table table-hover table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>Usuario</th>
            <th>Nombre</th>
            <th>Rol</th>
            <th>Estado</th>
            <th>Primer acceso</th>
            <th>Inicios</th>
            <th>Último acceso</th>
            <th class="text-center">Acciones</th>
        </tr>
    </thead>

    <tbody>

@foreach(var usuario in Model.Usuarios)
{
    <tr>

        <td>
            <strong>@usuario.Usuario</strong>
        </td>

        <td>
            @usuario.NombreCompleto
        </td>

        <td>
            @usuario.Rol
        </td>

        <td>

            @if (usuario.Activo)
            {
                <span class="badge bg-success">Activo</span>
            }
            else
            {
                <span class="badge bg-danger">Inactivo</span>
            }

        </td>

        <td>

            @if (usuario.PrimerAcceso)
            {
                <span class="badge bg-warning text-dark">
                    Sí
                </span>
            }
            else
            {
                <span class="badge bg-success">
                    No
                </span>
            }

        </td>

        <td class="text-center">
            @usuario.VecesInicioSesion
        </td>

        <td>

            @(usuario.FechaUltimoAcceso?.ToString("dd/MM/yyyy HH:mm")
                ?? "Nunca")

        </td>

        <td class="text-center">

            <a asp-action="RestablecerPassword"
                asp-route-id="@usuario.IdUsuario"
                class="btn btn-warning btn-sm">

                <i class="bi bi-key-fill"></i>
                Restablecer

            </a>

            @if (usuario.Activo)
            {
                <a asp-action="CambiarEstado"
                    asp-route-id="@usuario.IdUsuario"
                    class="btn btn-danger btn-sm">

                    <i class="bi bi-person-x-fill"></i>
                    Desactivar

                </a>
            }
            else
            {
                <a asp-action="CambiarEstado"
                    asp-route-id="@usuario.IdUsuario"
                    class="btn btn-success btn-sm">

                    <i class="bi bi-person-check-fill"></i>
                    Activar

                </a>
            }

        </td>

    </tr>
}

    </tbody>

</table>

</div>

@section Scripts{

<script>

document.getElementById("buscarUsuario")
.addEventListener("keyup", function () {

    let texto = this.value.toLowerCase();

    let filas = document.querySelectorAll("#tablaUsuarios tbody tr");

    filas.forEach(function(fila){

        let contenido = fila.innerText.toLowerCase();

        if(contenido.includes(texto))
            fila.style.display = "";
        else
            fila.style.display = "none";

    });

});

</script>

}
